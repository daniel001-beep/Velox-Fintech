      "static/css/app/fintech/layout.css",
      "static/chunks/app/fintech/layout.js"
    ],
    "/fintech/dashboard/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/fintech/dashboard/page.js"
    ],
    "/api/auth/[...nextauth]/route": [
