# Authentication (Auth.js v5)
# Generate a secret: npx auth secret
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Database (Postgres / Supabase)
# Non-pooling for migrations, pooling for the app
POSTGRES_URL="postgres://user:password@host:6543/postgres?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://user:password@host:5432/postgres?sslmode=require"

# Vercel Blob (Optional for product images)
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# AI SDK (Optional)
GOOGLE_GENERATIVE_AI_API_KEY="your-google-ai-api-key"
GROQ_API_KEY="your-groq-api-key"
